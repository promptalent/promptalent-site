{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/(.+\\.html)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
